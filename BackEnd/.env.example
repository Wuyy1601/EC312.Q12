# ── Server ──────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Frontend URL (CORS) ────────────────────
FRONTEND_URL=http://localhost:5173

# ── MongoDB URIs ────────────────────────────
MONGODB_USERS_URI=mongodb://localhost:27017/giftnity_users
MONGODB_PRODUCTS_URI=mongodb://localhost:27017/giftnity_products
MONGODB_ORDERS_URI=mongodb://localhost:27017/giftnity_orders
MONGODB_CALENDAR_URI=mongodb://localhost:27017/giftnity_calendar

# ── JWT ─────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret

# ── Google Gemini AI ────────────────────────
GEMINI_API_KEY=

# ── Email (Nodemailer) ─────────────────────
EMAIL_USER=
EMAIL_PASS=

# ── Web Push ────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ── Bank / QR Payment (SePay) ──────────────
BANK_ID=970422
BANK_ACCOUNT=
BANK_NAME=MB Bank
BANK_ACCOUNT_NAME=

# ── VNPay Sandbox ──────────────────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5001/api/orders/vnpay-return
